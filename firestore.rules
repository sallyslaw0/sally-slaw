rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Default deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Portfolio items - Everyone can read, anyone can write for simpler setup (without absolute OAuth constraints for now)
    match /portfolioItems/{itemId} {
      allow read: if true;
      allow write: if true;
    }

    // Settings - Everyone can read, anyone can write to modify UI settings online
    match /settings/{settingId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
